    <Target Name="PostBuild" AfterTargets="PostBuildEvent">
      <Exec Command="IF not exist &quot;$(SolutionDir)$(TargetName)\Release&quot; ( mkdir &quot;$(SolutionDir)$(TargetName)\Release&quot; )&#xA;&#xA;IF not exist &quot;$(SolutionDir)$(TargetName)\Release\mod.yaml&quot; (&#xA;    echo title: &quot;$(TargetName)&quot;&#xA;    echo description: &quot;&quot;&#xA;    echo staticID: &quot;CatPlasma.$(TargetName)&quot;&#xA;) &gt; &quot;$(SolutionDir)$(TargetName)\Release\mod.yaml&quot;&#xA;&#xA;for /f &quot;delims=&quot; %%i in ('powershell -command &quot;Get-Date -UFormat '%%Y.%%m.%%d'&quot;') do (&#xA;    set today=%%i&#xA;)&#xA;&#xA;IF not exist &quot;$(SolutionDir)$(TargetName)\Release\mod_info.yaml&quot; (&#xA;    echo supportedContent: ALL&#xA;    echo minimumSupportedBuild: 736649&#xA;    echo version: &quot;%today%&quot;&#xA;    echo APIVersion: 2&#xA;) &gt; &quot;$(SolutionDir)$(TargetName)\Release\mod_info.yaml&quot;&#xA;&#xA;D:\GitHub\ONI-Tools\yq.exe -i &quot;.version=\&quot;%today%\&quot;&quot; &quot;$(SolutionDir)$(TargetName)\Release\mod_info.yaml&quot;&#xA;&#xA;IF not exist &quot;C:\Users\A\Documents\Klei\OxygenNotIncluded\mods\Dev\$(TargetName)&quot; (mklink /J C:\Users\A\Documents\Klei\OxygenNotIncluded\mods\Dev\$(TargetName) $(SolutionDir)$(TargetName)\Release)&#xA;&#xA;$(ILRepack) /lib:$(SolutionDir)Libs /out:&quot;$(SolutionDir)$(TargetName)\Release\$(TargetName)Repacked.dll&quot; &quot;$(SolutionDir)$(TargetName)\bin\Release\netstandard2.1\$(TargetName).dll&quot; &quot;$(SolutionDir)$(TargetName)\bin\Release\netstandard2.1\CatUtilLib.dll&quot;" />
    </Target>

</Project>
