#. BetterReef.STRINGS.MISC.STATUSITEMS.UNDERWATERVENTBUILDUPPROGRESS.TOOLTIP
msgctxt "BetterReef.STRINGS.MISC.STATUSITEMS.UNDERWATERVENTBUILDUPPROGRESS.TOOLTIP"
msgid "This geyser will become blocked when <style=\"KKeyword\">{ELEMENT}</style> build-up reaches 100%\n\nIt can be unblocked by building a <style=\"KKeyword\">Marine Drill</style> on top of the vent"
msgstr ""

